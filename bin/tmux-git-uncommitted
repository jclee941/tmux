#!/usr/bin/env bash
# tmux-git-uncommitted — Uncommitted changes tracker for tmux
# Checks git status on session switch and displays warning

set -euo pipefail

# Get current pane's working directory
pane_path="${1:-$(tmux display-message -p '#{pane_current_path}')}"

# Check if directory is in a git repo (support subdirectories and worktrees)
cd "$pane_path" 2>/dev/null || exit 0

# Get git top-level directory
if ! git_toplevel=$(git rev-parse --show-toplevel 2>/dev/null); then
    exit 0
fi

# Get git status in porcelain format
if ! git_status=$(git status --porcelain 2>/dev/null); then
    exit 0
fi

# Count changes by status
staged_count=0
modified_count=0
untracked_count=0

while IFS= read -r line; do
    # Skip empty lines
    [ -z "$line" ] && continue
    
    # Get status from first two characters
    xy="${line:0:2}"
    x="${xy:0:1}"
    y="${xy:1:1}"
    
    # Staged changes (index has changes)
    if [[ "$x" =~ [MADRC] ]]; then
        staged_count=$((staged_count + 1))
    fi
    
    # Unstaged modifications (work tree has changes not in index)
    if [[ "$y" =~ [MAD] ]]; then
        modified_count=$((modified_count + 1))
    fi
    
    # Untracked files
    if [[ "$x" == "?" && "$y" == "?" ]]; then
        untracked_count=$((untracked_count + 1))
    fi
done <<< "$git_status"

# Format output
output=""

if [ "$staged_count" -gt 0 ]; then
    output="${output}⚡${staged_count}"
fi

if [ "$modified_count" -gt 0 ]; then
    output="${output}✎${modified_count}"
fi

if [ "$untracked_count" -gt 0 ]; then
    output="${output}?${untracked_count}"
fi

# Store result in tmux user option (no stdout — run-shell -b captures stdout into copy mode)
session=$(tmux display-message -p '#S')
if [ -n "$output" ]; then
    tmux set -t "$session" @git_dirty "$output"
else
    tmux set -t "$session" -u @git_dirty 2>/dev/null || true
fi
