#!/usr/bin/env bash
# tmux-opencode — create or attach to the 'opencode' session
# Bound to Home key. Excluded from normal session rotation.

set -euo pipefail

SESSION_NAME="opencode"
WORK_DIR="${HOME}/.config/opencode"

# Ensure working directory exists
mkdir -p "$WORK_DIR"

if tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
  tmux switch-client -t "=$SESSION_NAME"
else
  tmux new-session -d -s "$SESSION_NAME" -c "$WORK_DIR"
  tmux switch-client -t "=$SESSION_NAME"
fi
