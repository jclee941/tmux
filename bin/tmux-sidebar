#!/usr/bin/env bash
# tmux-sidebar — persistent session list panel (display-only)
# Runs in a narrow left pane, auto-refreshes every 1s
# Tokyo Night color scheme
#
# Sort: attached sessions first, then unattached (alphabetical within each)
# Highlight: > = current (blue bg stripe), * = attached (green), dim = inactive

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

source "${SCRIPT_DIR}/lib/sidebar-colors"
source "${SCRIPT_DIR}/lib/sidebar-render"

# Mosh detection — check env var (fast) or process tree (fallback)
is_mosh() {
    [[ -n "${MOSH_KEY:-}" ]] && return 0
    pstree -s $$ 2>/dev/null | grep -q mosh
}

# Refresh interval: gentle over mosh (save bandwidth), aggressive locally
if is_mosh; then
    REFRESH_INTERVAL=3
else
    REFRESH_INTERVAL=0.5
fi

# Hide cursor, restore on exit
setup_terminal() {
    tput civis 2>/dev/null  # hide cursor
    tput smcup 2>/dev/null  # alternate screen
    trap cleanup EXIT INT TERM
}

cleanup() {
    tput cnorm 2>/dev/null  # show cursor
    tput rmcup 2>/dev/null  # restore screen
    exit 0
}

# Main loop — smart redraw: skip if nothing changed
main() {
    setup_terminal
    local last_hash=""

    while true; do
        local state
        # Include a 5-minute bucket of session_activity so stale dimming updates
        # without rerendering on every keypress.
        state=$(tmux list-sessions -F '#{session_name}:#{session_attached}:#{session_windows}:#{session_activity}' 2>/dev/null \
            | while IFS=':' read -r sname satt swindows sactivity; do
                printf '%s:%s:%s:%s\n' "$sname" "$satt" "$swindows" "$((sactivity / 300))"
            done)

        local cur_hash
        cur_hash=$(echo "$state" | md5sum | cut -c1-16)

        if [[ "$cur_hash" != "$last_hash" ]]; then
            render
            last_hash="$cur_hash"
        fi

        sleep "$REFRESH_INTERVAL"
    done
}

main "$@"
