#!/usr/bin/env bash
set -euo pipefail

# Post-OAuth setup for tmux-slack-bridge.
# Reads OAuth result from /tmp/slack-oauth-result.json, updates .env,
# creates #tmux channel, invites bot, and enables systemd service.
#
# Usage: tmux-slack-bridge-setup [--oauth-file PATH]

BRIDGE_DIR="${TMUX_HOME:-$HOME/.tmux}/slack/tmux-bridge"
ENV_FILE="${BRIDGE_DIR}/.env"
OAUTH_FILE="${1:-/tmp/slack-oauth-result.json}"

# --- Helpers ---
die()  { echo "[setup] ERROR: $*" >&2; exit 1; }
info() { echo "[setup] $*"; }

# --- Step 1: Read OAuth result ---
info "Reading OAuth result from ${OAUTH_FILE}..."
[[ -f "$OAUTH_FILE" ]] || die "OAuth result file not found: ${OAUTH_FILE}"

BOT_TOKEN=$(python3 -c "
import json, sys
with open('${OAUTH_FILE}') as f:
    d = json.load(f)
    t = d.get('access_token') or d.get('bot', {}).get('access_token', '')
    if not t:
        print('', end='')
        sys.exit(1)
    print(t, end='')
" 2>/dev/null) || die "Failed to extract bot token from OAuth result"

[[ -n "$BOT_TOKEN" ]] || die "Bot token is empty in OAuth result"
info "Bot token extracted: ${BOT_TOKEN:0:20}...(truncated)"

# --- Step 2: Verify token works ---
info "Verifying bot token with auth.test..."
AUTH_RESULT=$(curl -s -X POST 'https://slack.com/api/auth.test' \
  -H "Authorization: Bearer ${BOT_TOKEN}" \
  -H 'Content-Type: application/json')

AUTH_OK=$(echo "$AUTH_RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('ok',''))" 2>/dev/null)
[[ "$AUTH_OK" == "True" ]] || die "Token verification failed: ${AUTH_RESULT}"

BOT_USER_ID=$(echo "$AUTH_RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('user_id',''))" 2>/dev/null)
info "Token verified. Bot user: ${BOT_USER_ID}"

# --- Step 3: Update .env with new bot token ---
info "Updating ${ENV_FILE} with new bot token..."
[[ -f "$ENV_FILE" ]] || die ".env file not found: ${ENV_FILE}"

if grep -q '^SLACK_BOT_TOKEN=' "$ENV_FILE"; then
  sed -i "s|^SLACK_BOT_TOKEN=.*|SLACK_BOT_TOKEN=${BOT_TOKEN}|" "$ENV_FILE"
else
  echo "SLACK_BOT_TOKEN=${BOT_TOKEN}" >> "$ENV_FILE"
fi
info "Bot token updated in .env"

# --- Step 4: Create #tmux channel ---
info "Creating #tmux channel..."
CREATE_RESULT=$(curl -s -X POST 'https://slack.com/api/conversations.create' \
  -H "Authorization: Bearer ${BOT_TOKEN}" \
  -H 'Content-Type: application/json' \
  -d '{"name": "tmux", "is_private": false}')

CREATE_OK=$(echo "$CREATE_RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('ok',''))" 2>/dev/null)
CHANNEL_ID=""

if [[ "$CREATE_OK" == "True" ]]; then
  CHANNEL_ID=$(echo "$CREATE_RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin)['channel']['id'])" 2>/dev/null)
  info "Created #tmux channel: ${CHANNEL_ID}"
else
  CREATE_ERROR=$(echo "$CREATE_RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error','unknown'))" 2>/dev/null)
  if [[ "$CREATE_ERROR" == "name_taken" ]]; then
    info "Channel #tmux already exists, looking it up..."
    LIST_RESULT=$(curl -s -X GET 'https://slack.com/api/conversations.list?types=public_channel&limit=200' \
      -H "Authorization: Bearer ${BOT_TOKEN}")
    CHANNEL_ID=$(echo "$LIST_RESULT" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for c in d.get('channels', []):
    if c.get('name') == 'tmux':
        print(c['id'], end='')
        sys.exit(0)
print('', end='')
" 2>/dev/null)
    if [[ -n "$CHANNEL_ID" ]]; then
      info "Found existing #tmux channel: ${CHANNEL_ID}"
      # Join the channel if not already a member
      curl -s -X POST 'https://slack.com/api/conversations.join' \
        -H "Authorization: Bearer ${BOT_TOKEN}" \
        -H 'Content-Type: application/json' \
        -d "{\"channel\": \"${CHANNEL_ID}\"}" >/dev/null
    else
      echo "[setup] WARNING: #tmux channel exists but could not find its ID" >&2
      echo "[setup] Set SLACK_CHANNEL_ID manually in ${ENV_FILE}" >&2
    fi
  else
    echo "[setup] WARNING: Channel creation failed: ${CREATE_ERROR}" >&2
    echo "[setup] Set SLACK_CHANNEL_ID manually in ${ENV_FILE}" >&2
  fi
fi

# --- Step 5: Update SLACK_CHANNEL_ID in .env ---
if [[ -n "$CHANNEL_ID" ]]; then
  if grep -q '^SLACK_CHANNEL_ID=' "$ENV_FILE"; then
    sed -i "s|^SLACK_CHANNEL_ID=.*|SLACK_CHANNEL_ID=${CHANNEL_ID}|" "$ENV_FILE"
  else
    echo "SLACK_CHANNEL_ID=${CHANNEL_ID}" >> "$ENV_FILE"
  fi
  info "Channel ID updated in .env: ${CHANNEL_ID}"

  # Post welcome message
  curl -s -X POST 'https://slack.com/api/chat.postMessage' \
    -H "Authorization: Bearer ${BOT_TOKEN}" \
    -H 'Content-Type: application/json' \
    -d "{\"channel\": \"${CHANNEL_ID}\", \"text\": \":tada: tmux-bridge connected! Use \`/tmux help\` to get started.\"}" >/dev/null
  info "Welcome message posted to #tmux"
fi

# --- Step 6: Reload tmux hooks ---
info "Reloading tmux configuration..."
if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null 2>&1; then
  tmux source-file "${TMUX_HOME:-$HOME/.tmux}/tmux.conf" 2>/dev/null || true
  info "tmux config reloaded (hooks active)"
else
  info "tmux not running, skipping config reload"
fi

# --- Step 7: Enable and start systemd service ---
info "Enabling tmux-slack-bridge systemd service..."
systemctl --user daemon-reload
systemctl --user enable tmux-slack-bridge.service
systemctl --user start tmux-slack-bridge.service

sleep 2
STATUS=$(systemctl --user is-active tmux-slack-bridge.service 2>/dev/null || true)
if [[ "$STATUS" == "active" ]]; then
  info "Service started successfully"
else
  echo "[setup] WARNING: Service status: ${STATUS}" >&2
  echo "[setup] Check logs: journalctl --user -u tmux-slack-bridge -n 50" >&2
fi

# --- Summary ---
echo ""
info "=== Setup Complete ==="
info "Bot token:  ${BOT_TOKEN:0:20}..."
info "Bot user:   ${BOT_USER_ID}"
[[ -n "$CHANNEL_ID" ]] && info "Channel:    #tmux (${CHANNEL_ID})"
info "Service:    ${STATUS:-unknown}"
info ""
info "Test: /tmux list (in Slack)"
info "Logs: journalctl --user -u tmux-slack-bridge -f"
