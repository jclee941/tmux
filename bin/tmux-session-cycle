#!/usr/bin/env bash
# tmux-session-cycle — cycle through sessions with wrap-around
# Usage: tmux-session-cycle next|prev [client_name] [current_session]

set -uo pipefail

direction="${1:-next}"
client="${2:-}"
current="${3:-$(tmux display-message -p '#S')}"

# Build sorted session list
sessions=()
while IFS= read -r name; do
  sessions+=("$name")
done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v '^opencode$' | sort)

(( ${#sessions[@]} == 0 )) && exit 0

# Find current session index
idx=-1
for i in "${!sessions[@]}"; do
  if [[ "${sessions[$i]}" == "$current" ]]; then
    idx=$i
    break
  fi
done

switch_to() {
  if [[ -n "$client" ]]; then
    tmux switch-client -c "$client" -t "$1"
  else
    tmux switch-client -t "$1"
  fi
}

# If current session is excluded or not found, jump to first
if (( idx < 0 )); then
  switch_to "${sessions[0]}"
  exit 0
fi

# Wrap-around next/prev
count=${#sessions[@]}
if [[ "$direction" == "next" ]]; then
  next_idx=$(( (idx + 1) % count ))
else
  next_idx=$(( (idx - 1 + count) % count ))
fi

switch_to "${sessions[$next_idx]}"
