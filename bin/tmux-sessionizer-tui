#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
TUI_DIR="${ROOT_DIR}/tui/sessionizer"
TUI_ENTRY="src/index.tsx"
LEGACY_ENTRY="${SCRIPT_DIR}/tmux-sessionizer"

if [[ -f "${TUI_DIR}/${TUI_ENTRY}" ]]; then
  run_tui() {
    local bun_bin="$1"
    shift
    set +e
    "${bun_bin}" run --cwd "${TUI_DIR}" "${TUI_ENTRY}" -- "$@"
    local exit_code=$?
    set -e
    return "${exit_code}"
  }

  if command -v bun >/dev/null 2>&1; then
    if run_tui "$(command -v bun)" "$@"; then
      exit 0
    fi
  fi

  if [[ -x "${HOME}/.bun/bin/bun" ]]; then
    if run_tui "${HOME}/.bun/bin/bun" "$@"; then
      exit 0
    fi
  fi
fi

exec "${LEGACY_ENTRY}" "$@"
