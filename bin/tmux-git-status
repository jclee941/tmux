#!/usr/bin/env bash
set -euo pipefail

pane_path="$(tmux display-message -p '#{pane_current_path}')"
cd "$pane_path" 2>/dev/null || exit 0
branch="$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)"
[[ -z "$branch" ]] && exit 0

dirty=""
git diff --quiet 2>/dev/null || dirty="*"
git diff --cached --quiet 2>/dev/null || dirty="${dirty}+"

# Ahead/behind upstream
local_ref="HEAD"
remote_ref="@{u}"
counts=$(git rev-list --left-right --count "$local_ref...$remote_ref" 2>/dev/null)
if [[ -n "$counts" ]]; then
  ahead=$(echo "$counts" | awk '{print $1}')
  behind=$(echo "$counts" | awk '{print $2}')
  [[ "$ahead" -gt 0 ]] && dirty="${dirty}↑${ahead}"
  [[ "$behind" -gt 0 ]] && dirty="${dirty}↓${behind}"
fi

# Stash count
stash_count=$(git stash list 2>/dev/null | wc -l)
[[ "$stash_count" -gt 0 ]] && dirty="${dirty}≡${stash_count}"

echo " ${branch}${dirty}"
