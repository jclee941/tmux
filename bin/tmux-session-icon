#!/usr/bin/env bash
# tmux-session-icon έΑΦ output icon for session name

set -euo pipefail

name="${1:-}"

case "$name" in
opencode*) echo '≤░γσ' ;;
git*) echo 'ΌεΓ' ;;
docker*) echo 'ΎΝΙ' ;;
node*) echo 'Όεα' ;;
tmux*) echo 'ΌψΙ' ;;
*)
    if [[ -z "$name" ]]; then
        echo '?'
    else
        echo "${name:0:1}" | tr '[:lower:]' '[:upper:]'
    fi
    ;;
esac
