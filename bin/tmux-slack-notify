#!/usr/bin/env bash
set -euo pipefail

# tmux-slack-notify — sends tmux hook events to the slack bridge notify endpoint
# Called by tmux hooks in conf.d/35-slack-hooks.conf

NOTIFY_PORT="${TMUX_SLACK_NOTIFY_PORT:-9876}"
NOTIFY_URL="http://127.0.0.1:${NOTIFY_PORT}/notify"

usage() {
  echo "Usage: tmux-slack-notify <event> <session> [details]" >&2
  echo "" >&2
  echo "Events: session-created, session-closed, session-renamed," >&2
  echo "        client-attached, client-detached" >&2
  exit 1
}

[[ $# -lt 2 ]] && usage

event="$1"
session="$2"
details="${3:-}"
timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

payload=$(printf '{"event":"%s","session":"%s","timestamp":"%s"' "$event" "$session" "$timestamp")
if [[ -n "$details" ]]; then
  payload="${payload},\"details\":\"${details}\"}"
else
  payload="${payload}}"
fi

# Fire-and-forget: don't block tmux if bridge is down
curl -s -X POST \
  -H "Content-Type: application/json" \
  -d "$payload" \
  --connect-timeout 2 \
  --max-time 5 \
  "$NOTIFY_URL" >/dev/null 2>&1 || true
