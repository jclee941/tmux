# Slack App credentials
# Manifest auto-update (used by tmux-slack-bridge-start to update tunnel URL)
SLACK_CONFIG_TOKEN=xoxe.xoxp-your-config-token
SLACK_APP_ID=A0YOUR_APP_ID

# Mode: "socket" (needs SLACK_APP_TOKEN) or "http" (needs cloudflared tunnel)
SLACK_MODE=socket
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_HTTP_PORT=3000

# All notifications go to this single channel (required)
SLACK_CHANNEL_OPENCODE=C0123456789

# tmux socket name (default: "default")
TMUX_SOCKET=default
# tmux home directory (default: $HOME/.tmux)
TMUX_HOME=

# Notification webhook port
TMUX_SLACK_NOTIFY_PORT=9876

# OpenCode SDK (optional — connects to local opencode server)
OPENCODE_URL=http://localhost:0
OPENCODE_DIRECTORY=
OPENCODE_ENABLED=true
