# Slack App credentials
# Manifest auto-update (used by tmux-slack-bridge-start to update tunnel URL)
SLACK_CONFIG_TOKEN=xoxe.xoxp-your-config-token
SLACK_APP_ID=A0YOUR_APP_ID

# Mode: "socket" (needs SLACK_APP_TOKEN) or "http" (needs cloudflared tunnel)
SLACK_MODE=http
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_HTTP_PORT=3000

# Fallback channel for notifications
SLACK_CHANNEL_ID=C0123456789
# Per-channel routing (overrides SLACK_CHANNEL_ID)
# opencode session events → #opencode channel
SLACK_CHANNEL_OPENCODE=
# All other tmux events → #tmux channel
SLACK_CHANNEL_TMUX=
# Comma-separated Slack user IDs to auto-invite to all managed channels
SLACK_INVITE_USERS=

# tmux socket name (default: "default")
TMUX_SOCKET=default
# tmux home directory (default: $HOME/.tmux)
TMUX_HOME=
# Directory to scan for project subdirs (default: $HOME/dev)
TMUX_SCAN_DIR=

# Notification webhook port — shared with bin/tmux-slack-notify
TMUX_SLACK_NOTIFY_PORT=9876

# Supermemory integration (optional)
SUPERMEMORY_ENABLED=false
SUPERMEMORY_URL=http://localhost:8050

# OpenCode SDK (optional — connects to local opencode server)
OPENCODE_URL=http://localhost:0
OPENCODE_DIRECTORY=/home/jclee/dev
OPENCODE_ENABLED=true
