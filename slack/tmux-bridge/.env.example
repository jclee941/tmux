# Slack App credentials (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Target channel for notifications
SLACK_CHANNEL_ID=C0123456789

# tmux socket name (default: "default")
TMUX_SOCKET=default
# tmux home directory (default: $HOME/.tmux)
TMUX_HOME=

# Notification webhook port — shared with bin/tmux-slack-notify
TMUX_SLACK_NOTIFY_PORT=9876

# Supermemory integration (optional)
SUPERMEMORY_ENABLED=false
SUPERMEMORY_URL=http://localhost:8050
